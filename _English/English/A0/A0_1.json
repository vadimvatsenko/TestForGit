  "sections": [
    {
      "title": "Present Simple",
      "rule": "Структура: подлежащее + глагол + … Для I: I + глагол + …",
      "examples": [
        { "en": "I agree", "ipa": "/aɪ əˈɡriː/", "ru": "Я согласен" },
        { "en": "I understand", "ipa": "/aɪ ˌʌndəˈstænd/", "ru": "Я понимаю" },
        { "en": "I know", "ipa": "/aɪ nəʊ/", "ru": "Я знаю" }
      ]
    },
    {
      "title": "Present Simple",
      "rule": "Структура (1.3): I / We / You / They + глагол + …",
      "examples": [
        { "en": "We support you", "ipa": "/wiː səˈpɔːt juː/", "ru": "Мы поддерживаем тебя" },
        { "en": "You do it very well", "ipa": "/juː duː ɪt ˈveri wel/", "ru": "Ты делаешь это очень хорошо" },
        { "en": "They want more", "ipa": "/ðeɪ wɒnt mɔː/", "ru": "Они хотят большего" }
      ]
    },
    {
      "title": "Present Simple",
      "rule": "Структура: I / We / You / They + глагол + …",
      "examples": [
        { "en": "I agree with you", "ipa": "/aɪ əˈɡriː wɪð juː/", "ru": "Я согласен с тобой" },
        { "en": "I support you", "ipa": "/aɪ səˈpɔːt juː/", "ru": "Я поддерживаю тебя" },
        { "en": "We see this problem", "ipa": "/wiː siː ðɪs ˈprɒbləm/", "ru": "Мы видим эту проблему" },
        { "en": "They work in this place", "ipa": "/ðeɪ wɜːk ɪn ðɪs pleɪs/", "ru": "Они работают в этом месте" }
      ]
    },
    {
      "title": "I have a / an … (1.4)",
      "rule": "a — перед согласным звуком, an — перед гласным звуком. (1.5) I have a + согласный звук",
      "examples": [
        { "en": "I have a friend", "ipa": "/aɪ hæv ə frend/", "ru": "У меня есть друг" },
        { "en": "I have a question", "ipa": "/aɪ hæv ə ˈkwestʃən/", "ru": "У меня вопрос" },
        { "en": "I have a ticket", "ipa": "/aɪ hæv ə ˈtɪkɪt/", "ru": "У меня есть билет" }
      ]
    },
    {
      "title": "I have a / an + гласный звук (1.6)",
      "rule": "an — перед гласным звуком (a, e, i, o, u). Важно: выбираем по звуку, не по букве.",
      "examples": [
        { "en": "I have an idea", "ipa": "/aɪ hæv ən aɪˈdɪə/", "ru": "У меня есть идея" },
        { "en": "I have an umbrella", "ipa": "/aɪ hæv ən ʌmˈbrelə/", "ru": "У меня есть зонт" },
        { "en": "I see a university", "ipa": "/aɪ siː ə ˌjuːnɪˈvɜːsɪti/", "ru": "Я вижу университет" }
      ]
    },
    {
      "title": "a / an (по звуку)",
      "rule": "an — перед гласным звуком, a — перед согласным.",
