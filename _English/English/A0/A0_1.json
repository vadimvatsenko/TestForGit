      "rule": "Структура: I see + a/an + предмет. a — перед согласным звуком, an — перед гласным.",
      "examples": [
        { "en": "I see a train", "ipa": "/aɪ siː ə treɪn/", "ru": "Я вижу поезд" },
        { "en": "I see a bus", "ipa": "/aɪ siː ə bʌs/", "ru": "Я вижу автобус" },
        { "en": "I have a result", "ipa": "/aɪ hæv ə rɪˈzʌlt/", "ru": "У меня есть результат" },
        { "en": "I have a family", "ipa": "/aɪ hæv ə ˈfæməli/", "ru": "У меня есть семья" }
      ]
    },
    {
      "title": "have / work in …",
      "rule": "Present Simple: I / You / They + глагол + …",
      "examples": [
        { "en": "You have a talent", "ipa": "/juː hæv ə ˈtælənt/", "ru": "У тебя есть талант" },
        { "en": "I work in a company", "ipa": "/aɪ wɜːk ɪn ə ˈkʌmpəni/", "ru": "Я работаю в компании" },
        { "en": "They work in a company", "ipa": "/ðeɪ wɜːk ɪn ə ˈkʌmpəni/", "ru": "Они работают в компании" },
        { "en": "I work in this company", "ipa": "/aɪ wɜːk ɪn ðɪs ˈkʌmpəni/", "ru": "Я работаю в этой компании" }
      ]
    },
    {
      "title": "I / We see… • I / They have…",
      "rule": "Present Simple: I / We / They + глагол + …",
      "examples": [
        { "en": "I see a message", "ipa": "/aɪ siː ə ˈmesɪdʒ/", "ru": "Я вижу сообщение" },
        { "en": "We see a message", "ipa": "/wiː siː ə ˈmesɪdʒ/", "ru": "Мы видим сообщение" },
        { "en": "I have a job", "ipa": "/aɪ hæv ə dʒɒb/", "ru": "У меня есть работа" },
        { "en": "They have a job", "ipa": "/ðeɪ hæv ə dʒɒb/", "ru": "У них есть работа" }
      ]
    },
    {
      "title": "I really + глагол … (1.7)",
      "rule": "Шаблоны: I really want … (1.8) — Я очень хочу …; I really like … (1.9) — Мне очень нравится …",
      "examples": [
        { "en": "I really want it", "ipa": "/aɪ ˈrɪəli wɒnt ɪt/", "ru": "Я очень хочу это" },
        { "en": "I really like it", "ipa": "/aɪ ˈrɪəli laɪk ɪt/", "ru": "Мне очень нравится это" }
      ]
    },
    {
      "title": "I really like … (усиление: “очень”)",
      "rule": "Структура: I really like + …",
      "examples": [
        { "en": "I really like this country", "ipa": "/aɪ ˈrɪəli laɪk ðɪs ˈkʌntri/", "ru": "Мне очень нравится эта страна" },
        { "en": "I really like this city", "ipa": "/aɪ ˈrɪəli laɪk ðɪs ˈsɪti/", "ru": "Мне очень нравится этот город" },
        { "en": "I really like this course", "ipa": "/aɪ ˈrɪəli laɪk ðɪs kɔːs/", "ru": "Мне очень нравится этот курс" },
        { "en": "I really like English", "ipa": "/aɪ ˈrɪəli laɪk ˈɪŋɡlɪʃ/", "ru": "Мне очень нравится английский" }
      ]
    }
  ]
}