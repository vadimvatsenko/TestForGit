        { "en": "I see a hotel", "ipa": "/aɪ siː ə həʊˈtel/", "ru": "Я вижу отель" },
        { "en": "I have a problem", "ipa": "/aɪ hæv ə ˈprɒbləm/", "ru": "У меня проблема" }
      ]
    },
    {
      "title": "I like … (1.7)",
